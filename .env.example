# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# ── Database ─────────────────────────────────────────────
# Matches the credentials in docker-compose.yml (local dev Postgres).
# Using your own local Postgres instead? Update this to match its credentials.
DATABASE_URL="postgresql://iam_user:iam_password@localhost:5432/iam_db"

# ── Better Auth core ─────────────────────────────────────
# Base URL Better Auth issues callbacks/redirects against.
BETTER_AUTH_URL="http://localhost:5001"
# Signing secret for sessions/tokens. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# ── OAuth social providers ───────────────────────────────
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Outbound email (verification, OTP, invites) ──────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_EMAIL=""
SMTP_PASS=""

# ── Cloudflare Turnstile (captcha) ───────────────────────
TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# ── Internal service-to-service auth ─────────────────────
INTERNAL_API_KEY=""
INTERNAL_API_SECRET=""

# ── Downstream service endpoints ─────────────────────────
INTERNAL_URL="http://localhost:5001"
FHIR_OPENAPI_URL=""

# ── OAuth / OIDC flow redirect pages ─────────────────────
LOGIN_PAGE="/sign-in"
SIGNUP_PAGE="/sign-up"
CONSENT_PAGE="/oauth2/consent"

# ── App metadata ──────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="bezs-iam"

# ── Logging ───────────────────────────────────────────────
LOG_DIR="./logs"

# ── Runtime flags ─────────────────────────────────────────
NODE_ENV="development"
DEBUG=""
